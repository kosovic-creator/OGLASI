generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  KLIENT
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      UserRole  @default(KLIENT)
  name      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
