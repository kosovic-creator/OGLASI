generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ===== ENUMS =====

enum UserRole {
  ADMIN
  KLIENT
}

enum AdCategory {
  NEKRETNINE
  BIJELA_TEHNIKA
  AUTOMOBILI
}

enum AdType {
  PRODAJA
  IZNAJMLJIVANJE
}

enum AdStatus {
  AKTIVNO
  NEAKTIVNO
  PRODATO
  IZNAJMLJENO
}

enum RealEstateType {
  STAN
  KUCA
  POSLOVNI_PROSTOR
}

enum HeatingType {
  CENTRALNO
  ETAZNO
  PLIN
  STRUJA
  PELET
  KRUTO_GORIVO
  TOPLOTNA_PUMPA
  KLIMA
}

enum VehicleType {
  AUTOMOBIL
  TERETNO
  MOTOCIKL
}

enum FuelType {
  BENZIN
  DIZEL
  HIBRID
  ELEKTRICNI
  PLIN
}

enum Transmission {
  MANUELNI
  AUTOMATIK
}

enum ItemCondition {
  NOVO
  KAO_NOVO
  DOBRO
  ZADOVOLJAVAJUCE
}

// ===== MODELS =====

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      UserRole  @default(KLIENT)
  name      String?
  phone     String?

  ads       Ad[]
  favorites Favorite[]
  contacts  Contact[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
}

model Ad {
  id          String      @id @default(cuid())
  title       String
  description String      @db.Text
  price       Decimal     @db.Decimal(12, 2)
  category    AdCategory
  type        AdType
  status      AdStatus    @default(AKTIVNO)

  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  locationId  String?
  location    Location?   @relation(fields: [locationId], references: [id])

  images      Image[]
  realEstate  RealEstate?
  whiteGoods  WhiteGoods?
  vehicle     Vehicle?
  favorites   Favorite[]
  contacts    Contact[]

  views       Int         @default(0)
  featured    Boolean     @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([category])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([featured])
}

model RealEstate {
  id              String          @id @default(cuid())
  adId            String          @unique
  ad              Ad              @relation(fields: [adId], references: [id], onDelete: Cascade)

  realEstateType  RealEstateType
  surface         Decimal         @db.Decimal(8, 2) // m²
  rooms           Int?
  bathrooms       Int?
  floor           Int?
  totalFloors     Int?

  yearBuilt       Int?
  heating         HeatingType?
  parking         Boolean         @default(false)
  elevator        Boolean         @default(false)
  balcony         Boolean         @default(false)
  terrace         Boolean         @default(false)
  garden          Boolean         @default(false)
  furnished       Boolean         @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([realEstateType])
}

model WhiteGoods {
  id              String          @id @default(cuid())
  adId            String          @unique
  ad              Ad              @relation(fields: [adId], references: [id], onDelete: Cascade)

  brand           String
  model           String
  condition       ItemCondition
  yearOfManufacture Int?
  warranty        Boolean         @default(false)
  warrantyMonths  Int?

  // Specifične karakteristike (može se koristiti JSON za fleksibilnost)
  energyClass     String?         // A+++, A++, A+, A, B, C, D
  capacity        String?         // npr. "7kg", "250L"
  features        String?         @db.Text // JSON string sa dodatnim karakteristikama

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([brand])
  @@index([condition])
}

model Vehicle {
  id              String          @id @default(cuid())
  adId            String          @unique
  ad              Ad              @relation(fields: [adId], references: [id], onDelete: Cascade)

  vehicleType     VehicleType
  brand           String
  model           String
  yearOfManufacture Int
  mileage         Int             // u kilometrima

  fuelType        FuelType
  transmission    Transmission
  enginePower     Int?            // KW
  engineVolume    Int?            // cm³

  condition       ItemCondition
  registeredUntil DateTime?

  color           String?
  doors           Int?
  seats           Int?

  // Dodatne karakteristike
  airbags         Boolean         @default(false)
  abs             Boolean         @default(false)
  airConditioning Boolean         @default(false)
  parkingSensors  Boolean         @default(false)
  cruiseControl   Boolean         @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([vehicleType])
  @@index([brand])
  @@index([yearOfManufacture])
  @@index([fuelType])
}

model Location {
  id          String    @id @default(cuid())
  country     String    @default("Bosna i Hercegovina")
  city        String
  municipality String?
  address     String?
  postalCode  String?

  latitude    Decimal?  @db.Decimal(10, 8)
  longitude   Decimal?  @db.Decimal(11, 8)

  ads         Ad[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([city])
  @@index([municipality])
}

model Image {
  id        String    @id @default(cuid())
  url       String
  alt       String?
  order     Int       @default(0)

  adId      String
  ad        Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@index([adId])
  @@index([order])
}

model Favorite {
  id        String    @id @default(cuid())

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  adId      String
  ad        Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@unique([userId, adId])
  @@index([userId])
  @@index([adId])
}

model Contact {
  id        String    @id @default(cuid())

  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  adId      String
  ad        Ad        @relation(fields: [adId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String?
  message   String    @db.Text

  replied   Boolean   @default(false)

  createdAt DateTime  @default(now())

  @@index([adId])
  @@index([userId])
  @@index([replied])
}
