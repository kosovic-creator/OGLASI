{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@oglasi/database": ["packages/database/index.ts"],
      "@oglasi/auth": ["packages/auth/index.ts"],
      "@oglasi/server-actions": ["packages/server-actions/index.ts"],
      "@oglasi/validation": ["packages/validation/index.ts"],
      "@oglasi/*": ["packages/*/index.ts"]
    },
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
